{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },

  "Jwt": {
    "Key": "YOUR_JWT_SECRET",
    "ValidIssuer": "YOUR_ISSUER",
    "ValidAudience": "YOUR_AUDIENCE"
  },
  "SecretKey": "YOUR_SECRET_KEY"

}
